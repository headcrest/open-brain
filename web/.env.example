# MCP Server credentials
# Copy this file to `.env.local` for local development.
# SvelteKit only picks up env changes after restarting `npm run dev`.
#
# Preferred (server-only, does not expose key in browser):
MCP_URL=https://your-project.supabase.co/functions/v1/open-brain-mcp
MCP_KEY=your-access-key

# Optional primary capture tool defaults (fallbacks)
MCP_CAPTURE_TOOLS=capture_thought
MCP_CAPTURE_DEFAULT_TOOL=capture_thought

# Multi-server config (optional, replaces MCP_URL/MCP_KEY when set)
# JSON array of server objects with capture tools and optional default.
# - url: MCP endpoint
# - key: MCP access key
# - id or name/label: human-readable identifier
# - captureTools: list of tools available for capture
# - captureDefaultTool: default selected capture tool
#MCP_SERVERS=[{"id":"primary","name":"Primary MCP","url":"https://your-project.supabase.co/functions/v1/open-brain-mcp","key":"your-access-key","captureTools":["capture_thought","capture_thought_reference"],"captureDefaultTool":"capture_thought"}]

# Backward-compatible fallback (works, but values are public in browser bundle):
# PUBLIC_MCP_URL=https://your-project.supabase.co/functions/v1/open-brain-mcp
# PUBLIC_MCP_KEY=your-access-key
# PUBLIC_MCP_CAPTURE_TOOLS=capture_thought
# PUBLIC_MCP_CAPTURE_DEFAULT_TOOL=capture_thought

# Supabase auth credentials
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
